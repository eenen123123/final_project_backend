<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.RefreshTokenMapper">
    <select id="findByToken" resultType="kr.or.ddit.finalProject.dto.user.RefreshTokenDto">
        SELECT * FROM refresh_tokens WHERE token = #{token}
    </select>



    <insert id="upsertRefreshToken" parameterType="kr.or.ddit.finalProject.dto.user.RefreshTokenDto">
        merge 
        INTO refresh_tokens rt
        using  dual
        on (rt.user_id = #{userId})
        when matched then 
            update set token = #{token}, expired_at = #{expiredAt}
        when not matched then
            insert (user_id, token, expired_at) values (#{userId}, #{token}, #{expiredAt})
    </insert>
    <delete id="deleteRefreshToken">
        DELETE FROM refresh_tokens WHERE user_id = #{userId}
    </delete>

    <select id="findByUserId" resultType="kr.or.ddit.finalProject.dto.user.RefreshTokenDto">
        SELECT * FROM refresh_tokens WHERE user_id = #{userId}
    </select>
</mapper>