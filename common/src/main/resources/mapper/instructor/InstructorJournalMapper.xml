<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.instructor.InstructorJournalMapper">

    <!--
        공통 SELECT 컬럼 절 (목록·상세 공유)
          - MEMBER JOIN : 강사 이름(instrUserNm)
    -->
    <sql id="journalColumns">
        j.JRNL_SN,
        j.INSTR_USER_ID                              AS instrUserId,
        m.USER_NAME                                  AS instrUserNm,
        j.JRNL_TITLE,
        j.JRNL_CONT,
        TO_CHAR(j.JRNL_DT,   'YYYY-MM-DD')          AS jrnlDt,
        TO_CHAR(j.REG_DT,    'YYYY-MM-DD HH24:MI')  AS regDt,
        TO_CHAR(j.MDFCN_DT,  'YYYY-MM-DD HH24:MI')  AS mdfcnDt
    </sql>

    <!--
        공통 FROM + JOIN 절
          - MEMBER : 강사 이름 조회 (INSTRUCTOR 테이블을 경유하지 않음)
          - FK가 MEMBER(USER_ID)를 참조하므로 직접 JOIN 가능
    -->
    <sql id="journalFrom">
        FROM INSTRUCTOR_JOURNAL j
        JOIN MEMBER m ON j.INSTR_USER_ID = m.USER_ID
    </sql>

    <!-- 공통 WHERE 조건 (목록 조회 / 카운트 공유) -->
    <sql id="journalWhere">
        WHERE j.DEL_YN = 'N'
        <if test="instrUserId != null">
            AND j.INSTR_USER_ID = #{instrUserId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND UPPER(j.JRNL_TITLE) LIKE '%' || UPPER(#{keyword}) || '%'
        </if>
        <if test="fromDt != null and fromDt != ''">
            AND j.JRNL_DT &gt;= TO_DATE(#{fromDt}, 'YYYY-MM-DD')
        </if>
        <if test="toDt != null and toDt != ''">
            AND TRUNC(j.JRNL_DT) &lt;= TO_DATE(#{toDt}, 'YYYY-MM-DD')
        </if>
    </sql>

    <!-- ──────────────────────────────────────────────────────── -->
    <!-- 일지 목록 조회 (검색 필터 + 페이지네이션)               -->
    <!--   instrUserId null → 전체 강사 (뷰어용)                 -->
    <!--   offset / pageSize → Oracle OFFSET FETCH 페이징        -->
    <!-- ──────────────────────────────────────────────────────── -->
    <select id="selectJournalList"
            resultType="kr.or.ddit.finalProject.dto.instructor.journal.InstructorJournalDto">
        SELECT <include refid="journalColumns"/>
        <include refid="journalFrom"/>
        <include refid="journalWhere"/>
        ORDER BY j.JRNL_DT DESC, j.JRNL_SN DESC
        OFFSET #{offset} ROWS FETCH NEXT #{pageSize} ROWS ONLY
    </select>

    <!-- ──────────────────────────────────────────────────────── -->
    <!-- 일지 전체 건수 조회 (페이지네이션 총 페이지 계산용)      -->
    <!-- ──────────────────────────────────────────────────────── -->
    <select id="selectJournalCount" resultType="int">
        SELECT COUNT(*)
        <include refid="journalFrom"/>
        <include refid="journalWhere"/>
    </select>

    <!-- ──────────────────────────────────────────────────────── -->
    <!-- 일지를 작성한 강사 목록 (뷰어 강사 필터 드롭다운용)    -->
    <!-- instrUserId / instrUserNm 만 반환 (삭제되지 않은 일지 기준) -->
    <!-- ──────────────────────────────────────────────────────── -->
    <select id="selectJournalInstructors"
            resultType="kr.or.ddit.finalProject.dto.instructor.journal.InstructorJournalDto">
        SELECT DISTINCT j.INSTR_USER_ID AS instrUserId, m.USER_NAME AS instrUserNm
        FROM INSTRUCTOR_JOURNAL j
        JOIN MEMBER m ON j.INSTR_USER_ID = m.USER_ID
        WHERE j.DEL_YN = 'N'
        ORDER BY instrUserNm
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 일지 단건 상세 조회                          -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectJournalBySn"
            resultType="kr.or.ddit.finalProject.dto.instructor.journal.InstructorJournalDto">
        SELECT <include refid="journalColumns"/>
        <include refid="journalFrom"/>
        WHERE j.JRNL_SN = #{jrnlSn}
          AND j.DEL_YN = 'N'
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 일지 등록                                    -->
    <!-- useGeneratedKeys: INSERT 후 PK를 dto.jrnlSn 에 자동 주입 -->
    <!-- ──────────────────────────────────────────── -->
    <insert id="insertJournal"
            parameterType="kr.or.ddit.finalProject.dto.instructor.journal.InstructorJournalDto"
            useGeneratedKeys="true"
            keyProperty="jrnlSn"
            keyColumn="JRNL_SN">
        INSERT INTO INSTRUCTOR_JOURNAL (
            INSTR_USER_ID,
            JRNL_TITLE,
            JRNL_CONT,
            JRNL_DT
        ) VALUES (
            #{instrUserId},
            #{jrnlTitle},
            #{jrnlCont},
            TO_DATE(#{jrnlDt}, 'YYYY-MM-DD')
        )
    </insert>

    <!-- ──────────────────────────────────────────── -->
    <!-- 일지 수정                                    -->
    <!-- MDFCN_DT 를 CURRENT_TIMESTAMP 로 갱신       -->
    <!-- ──────────────────────────────────────────── -->
    <update id="updateJournal"
            parameterType="kr.or.ddit.finalProject.dto.instructor.journal.InstructorJournalDto">
        UPDATE INSTRUCTOR_JOURNAL
        SET
            JRNL_TITLE = #{jrnlTitle},
            JRNL_CONT  = #{jrnlCont},
            JRNL_DT    = TO_DATE(#{jrnlDt}, 'YYYY-MM-DD'),
            MDFCN_DT   = CURRENT_TIMESTAMP
        WHERE JRNL_SN = #{jrnlSn}
    </update>

    <!-- ──────────────────────────────────────────── -->
    <!-- 일지 소프트 딜리트                           -->
    <!-- DEL_YN='Y' 로 표시하고 삭제자/일시 기록     -->
    <!-- ──────────────────────────────────────────── -->
    <update id="deleteJournal">
        UPDATE INSTRUCTOR_JOURNAL
        SET
            DEL_YN      = 'Y',
            DEL_DT      = CURRENT_TIMESTAMP,
            DEL_USER_ID = #{delUserId}
        WHERE JRNL_SN = #{jrnlSn}
    </update>

</mapper>
