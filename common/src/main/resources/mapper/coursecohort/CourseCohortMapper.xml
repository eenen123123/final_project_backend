<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.coursecohort.CourseCohortMapper">

  <resultMap id="cohortListResponseMap" type="kr.or.ddit.finalProject.dto.coursecohort.CourseCohortListResponse">
    <result property="cohortSn"      column="COHORT_SN" />
    <result property="cohortYear"    column="COHORT_YEAR" />
    <result property="cohortStatCd"  column="COHORT_STAT_CD" />
    <result property="cohortStrtYmd" column="COHORT_STRT_YMD" />
    <result property="cohortEndYmd"  column="COHORT_END_YMD" />
    <result property="curEnrlCnt"    column="CUR_ENRL_CNT" />
    <result property="totLrnTimeCnt" column="TOT_LRN_TIME_CNT" />
  </resultMap>

  <select id="selectCohortsByClassSn" resultMap="cohortListResponseMap">
    SELECT
        cc.COHORT_SN,
        cc.COHORT_YEAR,
        cc.COHORT_STAT_CD,
        cc.COHORT_STRT_YMD,
        cc.COHORT_END_YMD,
        cc.CUR_ENRL_CNT,
        cc.TOT_LRN_TIME_CNT
    FROM COURSE_COHORT cc
    WHERE cc.COURSE_SN = (
        SELECT COURSE_SN FROM CLASSROOM WHERE CLASS_SN = #{classSn}
    )
    ORDER BY cc.COHORT_STRT_YMD DESC
  </select>

</mapper>
