<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.StaffMapper">

    <!-- selectDepartmentList --> 
    <select id="selectDepartmentList" resultType="kr.or.ddit.finalProject.dto.employee.DepartmentDto">
        SELECT
            DEPT_CD
            , PRNT_DEPT_CD
            , DEPT_NM
            , USE_YN
            , INTL_TEL_NO
            , RGTR_ID
            , LAST_MDFR_ID
            , REG_DT
            , MDFCN_DT
        FROM
            DEPARTMENT
    </select>      

    <!-- selectJobGradeList --> 
    <select id="selectJobGradeList" resultType="kr.or.ddit.finalProject.dto.employee.JobGradeDto">
        SELECT
            JBGR_CD
            , JBGR_NM
            , SORT_ORD
            , USE_YN
            , BASE_ANN_LV_DAYS
            , RGTR_ID
            , LAST_MDFR_ID
            , REG_DT
            , MDFCN_DT
            , DEPT_CD
        FROM
            JOB_GRADE
        WHERE USE_YN = 'Y'
        ORDER BY SORT_ORD
    </select>
</mapper>
