<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.exam.ExamMapper">

    <!--
        EXAM 공통 SELECT 컬럼 절
          테이블 별칭 없이 사용하는 단건 조회용 기본 컬럼 절입니다.
          selectMyExams에서는 테이블 별칭 E를 사용하므로 별도 처리합니다.
    -->
    <sql id="examColumns">
        EXAM_SN                                          AS examSn,
        EXAM_TYPE_CD                                     AS examTypeCd,
        EXAM_CHRG_USER_ID                                AS examChrgUserId,
        EXAM_REG_NM                                      AS examRegNm,
        TO_CHAR(EXAM_REG_DT, 'YYYY-MM-DD HH24:MI')      AS examRegDt,
        TO_CHAR(EXAM_STRT_DT, 'YYYY-MM-DD HH24:MI')     AS examStrtDt,
        TO_CHAR(EXAM_END_DT, 'YYYY-MM-DD HH24:MI')      AS examEndDt,
        EXAM_STAT_CD                                     AS examStatCd
    </sql>

    <!-- ──────────────────────────────────────────── -->
    <!-- 특정 강사의 시험 전체 조회                  -->
    <!--   EXAM_STAT_CD = '99'(삭제) 제외            -->
    <!--   qstnCnt: 배정된 문항 수 (서브쿼리)        -->
    <!--   등록일시 내림차순 정렬                     -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectMyExams"
            resultType="kr.or.ddit.finalProject.dto.exam.ExamDto">
        SELECT
            E.EXAM_SN                                          AS examSn,
            E.EXAM_TYPE_CD                                     AS examTypeCd,
            E.EXAM_CHRG_USER_ID                                AS examChrgUserId,
            E.EXAM_REG_NM                                      AS examRegNm,
            TO_CHAR(E.EXAM_REG_DT,  'YYYY-MM-DD HH24:MI')     AS examRegDt,
            TO_CHAR(E.EXAM_STRT_DT, 'YYYY-MM-DD HH24:MI')     AS examStrtDt,
            TO_CHAR(E.EXAM_END_DT,  'YYYY-MM-DD HH24:MI')     AS examEndDt,
            E.EXAM_STAT_CD                                     AS examStatCd,
            (SELECT COUNT(*)
             FROM EXAM_QUESTION EQ
             WHERE EQ.EXAM_SN = E.EXAM_SN)                    AS qstnCnt
        FROM EXAM E
        WHERE E.EXAM_CHRG_USER_ID = #{examChrgUserId}
          AND E.EXAM_STAT_CD != '99'
        ORDER BY E.EXAM_REG_DT DESC
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 시험 단건 조회                               -->
    <!--   삭제된 시험도 조회 (서비스에서 STAT_CD 판단) -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectExamBySn"
            resultType="kr.or.ddit.finalProject.dto.exam.ExamDto">
        SELECT <include refid="examColumns"/>
        FROM EXAM
        WHERE EXAM_SN = #{examSn}
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 특정 시험에 배정된 문항 목록 조회            -->
    <!--   EXAM_QUESTION + QUESTION_LIST JOIN         -->
    <!--   QSTN_CN(CLOB)에서 stem만 추출하지 않고    -->
    <!--   전체 JSON을 반환 — 서비스에서 파싱         -->
    <!--   QSTN_ORDR 오름차순 정렬                   -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectExamQuestions"
            resultType="kr.or.ddit.finalProject.dto.exam.ExamQuestionDto">
        SELECT
            EQ.EXAM_SN        AS examSn,
            EQ.QSTN_SN        AS qstnSn,
            EQ.QSTN_ORDR      AS qstnOrdr,
            QL.QSTN_TYPE_CD   AS qstnTypeCd,
            QL.QSTN_CN        AS stem,
            QL.ALLOC_SCR      AS allocScr,
            QL.CORR_ANSW_CN   AS corrAnswCn,
            QL.RGTR_ID        AS rgtrId
        FROM EXAM_QUESTION EQ
        JOIN QUESTION_LIST QL ON QL.QSTN_SN = EQ.QSTN_SN
        WHERE EQ.EXAM_SN = #{examSn}
          AND QL.STAT_CD != '99'
        ORDER BY EQ.QSTN_ORDR ASC
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 시험 등록                                    -->
    <!--   GENERATED BY DEFAULT AS IDENTITY로        -->
    <!--   EXAM_SN을 자동 채번합니다.                -->
    <!--   EXAM_REG_DT = CURRENT_TIMESTAMP 자동 설정 -->
    <!--   EXAM_STRT_DT / EXAM_END_DT: datetime-local -->
    <!--   입력값("YYYY-MM-DDTHH:mm")을 TIMESTAMP로  -->
    <!--   변환합니다.                               -->
    <!-- ──────────────────────────────────────────── -->
    <insert id="insertExam"
            parameterType="kr.or.ddit.finalProject.dto.exam.ExamDto"
            useGeneratedKeys="true"
            keyProperty="examSn"
            keyColumn="EXAM_SN">
        INSERT INTO EXAM (
            EXAM_TYPE_CD,
            EXAM_CHRG_USER_ID,
            EXAM_REG_NM,
            EXAM_REG_DT,
            EXAM_STRT_DT,
            EXAM_END_DT,
            EXAM_STAT_CD
        ) VALUES (
            #{examTypeCd,   jdbcType=VARCHAR},
            #{examChrgUserId},
            #{examRegNm},
            CURRENT_TIMESTAMP,
            <choose>
                <when test="examStrtDt != null and examStrtDt != ''">
                    TO_TIMESTAMP(#{examStrtDt}, 'YYYY-MM-DD"T"HH24:MI')
                </when>
                <otherwise>NULL</otherwise>
            </choose>,
            <choose>
                <when test="examEndDt != null and examEndDt != ''">
                    TO_TIMESTAMP(#{examEndDt}, 'YYYY-MM-DD"T"HH24:MI')
                </when>
                <otherwise>NULL</otherwise>
            </choose>,
            '01'
        )
    </insert>

    <!-- ──────────────────────────────────────────── -->
    <!-- 시험 수정                                    -->
    <!-- ──────────────────────────────────────────── -->
    <update id="updateExam"
            parameterType="kr.or.ddit.finalProject.dto.exam.ExamDto">
        UPDATE EXAM
        SET
            EXAM_TYPE_CD  = #{examTypeCd, jdbcType=VARCHAR},
            EXAM_REG_NM   = #{examRegNm},
            EXAM_STRT_DT  =
                <choose>
                    <when test="examStrtDt != null and examStrtDt != ''">
                        TO_TIMESTAMP(#{examStrtDt}, 'YYYY-MM-DD"T"HH24:MI')
                    </when>
                    <otherwise>NULL</otherwise>
                </choose>,
            EXAM_END_DT   =
                <choose>
                    <when test="examEndDt != null and examEndDt != ''">
                        TO_TIMESTAMP(#{examEndDt}, 'YYYY-MM-DD"T"HH24:MI')
                    </when>
                    <otherwise>NULL</otherwise>
                </choose>
        WHERE EXAM_SN = #{examSn}
          AND EXAM_STAT_CD != '99'
    </update>

    <!-- ──────────────────────────────────────────── -->
    <!-- 시험 논리 삭제                               -->
    <!--   EXAM_STAT_CD = '99'로 변경                -->
    <!-- ──────────────────────────────────────────── -->
    <update id="deleteExam">
        UPDATE EXAM
        SET EXAM_STAT_CD = '99'
        WHERE EXAM_SN = #{examSn}
          AND EXAM_STAT_CD != '99'
    </update>

    <!-- ──────────────────────────────────────────── -->
    <!-- 시험-문항 연결 행 삽입 (EXAM_QUESTION)       -->
    <!-- ──────────────────────────────────────────── -->
    <insert id="insertExamQuestion"
            parameterType="kr.or.ddit.finalProject.dto.exam.ExamQuestionDto">
        INSERT INTO EXAM_QUESTION (
            EXAM_SN,
            QSTN_SN,
            QSTN_ORDR
        ) VALUES (
            #{examSn},
            #{qstnSn},
            #{qstnOrdr}
        )
    </insert>

    <!-- ──────────────────────────────────────────── -->
    <!-- 특정 시험의 EXAM_QUESTION 전체 삭제          -->
    <!--   시험 수정 시 기존 배정 초기화용            -->
    <!-- ──────────────────────────────────────────── -->
    <delete id="deleteExamQuestions">
        DELETE FROM EXAM_QUESTION
        WHERE EXAM_SN = #{examSn}
    </delete>

</mapper>
