<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.ddit.finalProject.mapper.exam.QuestionMapper">

    <!--
        공통 SELECT 컬럼 절
          QUESTION_LIST 테이블 주요 컬럼을 camelCase DTO 필드에 매핑합니다.
          QSTN_CN(CLOB)은 문항 본문+보기를 JSON 문자열로 저장합니다.
          FIELD5는 DDL 상 의미 불명 TIMESTAMP 컬럼으로, MDFCN_DT로 추정됩니다.
    -->
    <sql id="questionColumns">
        QSTN_SN                                      AS qstnSn,
        SUBJ_DTCL_CD                                 AS subjDtclCd,
        RGTR_ID                                      AS rgtrId,
        LAST_MDFR_ID                                 AS lastMdfrId,
        TO_CHAR(REG_DT, 'YYYY-MM-DD HH24:MI')        AS regDt,
        QSTN_TYPE_CD                                 AS qstnTypeCd,
        ALLOC_SCR                                    AS allocScr,
        CORR_ANSW_CN                                 AS corrAnswCn,
        QSTN_CN                                      AS qstnCn,
        EXPLN_CN                                     AS explnCn,
        STAT_CD                                      AS statCd
    </sql>

    <!-- ──────────────────────────────────────────── -->
    <!-- 특정 강사의 문항 전체 조회                  -->
    <!--   STAT_CD = '99'(삭제) 제외                 -->
    <!--   유형(qstnTypeCd) → 등록일시 내림차순      -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectMyQuestions"
            resultType="kr.or.ddit.finalProject.dto.exam.QuestionDto">
        SELECT <include refid="questionColumns"/>
        FROM QUESTION_LIST
        WHERE RGTR_ID = #{rgtrId}
          AND STAT_CD != '99'
        ORDER BY QSTN_TYPE_CD ASC, REG_DT DESC
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 문항 단건 조회                               -->
    <!--   삭제된 항목도 조회 (서비스에서 STAT_CD 판단) -->
    <!-- ──────────────────────────────────────────── -->
    <select id="selectQuestionBySn"
            resultType="kr.or.ddit.finalProject.dto.exam.QuestionDto">
        SELECT <include refid="questionColumns"/>
        FROM QUESTION_LIST
        WHERE QSTN_SN = #{qstnSn}
    </select>

    <!-- ──────────────────────────────────────────── -->
    <!-- 문항 등록                                    -->
    <!--   GENERATED BY DEFAULT AS IDENTITY로        -->
    <!--   QSTN_SN을 자동 채번합니다.                -->
    <!--   useGeneratedKeys로 dto.qstnSn에 주입.     -->
    <!-- ──────────────────────────────────────────── -->
    <insert id="insertQuestion"
            parameterType="kr.or.ddit.finalProject.dto.exam.QuestionDto"
            useGeneratedKeys="true"
            keyProperty="qstnSn"
            keyColumn="QSTN_SN">
        INSERT INTO QUESTION_LIST (
            SUBJ_DTCL_CD,
            RGTR_ID,
            REG_DT,
            QSTN_TYPE_CD,
            ALLOC_SCR,
            CORR_ANSW_CN,
            QSTN_CN,
            EXPLN_CN,
            STAT_CD
        ) VALUES (
            #{subjDtclCd,   jdbcType=VARCHAR},
            #{rgtrId},
            CURRENT_TIMESTAMP,
            #{qstnTypeCd},
            #{allocScr,     jdbcType=NUMERIC},
            #{corrAnswCn,   jdbcType=VARCHAR},
            #{qstnCn,       jdbcType=CLOB},
            #{explnCn,      jdbcType=VARCHAR},
            '01'
        )
    </insert>

    <!-- ──────────────────────────────────────────── -->
    <!-- 문항 수정                                    -->
    <!--   LAST_MDFR_ID / FIELD5(MDFCN_DT 추정) 갱신 -->
    <!-- ──────────────────────────────────────────── -->
    <update id="updateQuestion"
            parameterType="kr.or.ddit.finalProject.dto.exam.QuestionDto">
        UPDATE QUESTION_LIST
        SET
            QSTN_TYPE_CD = #{qstnTypeCd},
            ALLOC_SCR    = #{allocScr,    jdbcType=NUMERIC},
            CORR_ANSW_CN = #{corrAnswCn,  jdbcType=VARCHAR},
            QSTN_CN      = #{qstnCn,      jdbcType=CLOB},
            EXPLN_CN     = #{explnCn,     jdbcType=VARCHAR},
            LAST_MDFR_ID = #{lastMdfrId},
            FIELD5       = CURRENT_TIMESTAMP
        WHERE QSTN_SN = #{qstnSn}
          AND STAT_CD != '99'
    </update>

    <!-- ──────────────────────────────────────────── -->
    <!-- 문항 논리 삭제                               -->
    <!--   STAT_CD = '99'로 변경 (DEL_YN 컬럼 없음)  -->
    <!-- ──────────────────────────────────────────── -->
    <update id="deleteQuestion">
        UPDATE QUESTION_LIST
        SET STAT_CD = '99'
        WHERE QSTN_SN = #{qstnSn}
          AND STAT_CD != '99'
    </update>

</mapper>
